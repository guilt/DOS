@ECHO OFF
REM DOSBox Autoexec

REM Avoid Recursion
IF "%AUTOEXECED%" == "YES" GOTO END
SET AUTOEXECED=YES

REM Limits Variables
FILES=100
FCBS=100,0

REM Switch Drive
C:

REM System Dirs
SET TEMP=C:\TEMP
SET TMPDIR=%TEMP%

REM External Development Directory
SET EXTDEV=C:\EXTDEV

REM ========== DEVELOPMENT TOOLS ==========

REM 3DGFX - 3D Graphics Library
SET _3DGFX_HOME=%EXTDEV%\3DGFX
SET INCLUDE=%_3DGFX_HOME%\INCLUDE
SET PATH=%PATH%;%_3DGFX_HOME%\EXAMPLES

REM FG - FastGraph
SET FG_HOME=%EXTDEV%\FG
SET PATH=%PATH%;%FG_HOME%
SET INCLUDE=%INCLUDE%;%FG_HOME%\INCLUDE
SET LIB=%LIB%;%FG_HOME%\LIB

REM Borland C++ 3.0
GOTO NOBC
IF NOT EXIST %EXTDEV%\BORLANDC\NUL GOTO NOBC
SET BC_HOME=%EXTDEV%\BORLANDC
SET PATH=%PATH%;%BC_HOME%\BIN
SET INCLUDE=%INCLUDE%;%BC_HOME%\INCLUDE;%BC_HOME%\CLASSLIB\INCLUDE;%BC_HOME%\OWL\INCLUDE
SET LIB=%LIB%;%BC_HOME%\LIB;%BC_HOME%\CLASSLIB\LIB;%BC_HOME%\OWL\LIB
:NOBC

REM Borland C++ 4.5
IF NOT EXIST %EXTDEV%\BC45\NUL GOTO NOBC45
SET BC45_HOME=%EXTDEV%\BC45
SET PATH=%PATH%;%BC45_HOME%\BIN
SET INCLUDE=%INCLUDE%;%BC45_HOME%\INCLUDE;%BC45_HOME%\CLASSLIB\INCLUDE;%BC45_HOME%\OWL\INCLUDE
SET LIB=%LIB%;%BC45_HOME%\LIB;%BC45_HOME%\CLASSLIB\LIB;%BC45_HOME%\OWL\LIB
:NOBC45

REM Turbo Assembler
IF NOT EXIST %EXTDEV%\TASM\NUL GOTO NOTASM
SET TASM_HOME=%EXTDEV%\TASM
SET PATH=%PATH%;%TASM_HOME%\BIN
:NOTASM

REM TVision
IF NOT EXIST %EXTDEV%\TVISION\NUL GOTO NOTV
SET TV_HOME=%EXTDEV%\TVISION
SET PATH=%PATH%;%TV_HOME%\BIN\BCC\X86
SET INCLUDE=%INCLUDE%;%TV_HOME%\INCLUDE
SET LIB=%LIB%;%TV_HOME%\LIB\BCC\X86
:NOTV

REM Turbo Pascal
IF NOT EXIST %EXTDEV%\TP\NUL GOTO NOTP
SET TP_HOME=%EXTDEV%\TP
SET PATH=%PATH%;%TP_HOME%
SET TPP_HOME=%EXTDEV%\TPPATCH
SET PATH=%PATH%;%TPP_HOME%
:NOTP

REM Free Pascal
IF NOT EXIST %EXTDEV%\PP\NUL GOTO NOPP
SET PPDIR=%EXTDEV%\PP
SET PPPLAT=GO32V2
SET PATH=%PATH%;%PPDIR%\BIN\%PPPLAT%
:NOPP

REM DJGPP
IF NOT EXIST %EXTDEV%\DJGPP\NUL GOTO NODJ
SET DJDIR=%EXTDEV%\DJGPP
SET DJGPP=%DJDIR%\DJGPP.ENV
SET PATH=%PATH%;%DJDIR%\BIN
SET LFN=no
:NODJ

REM Open Watcom
IF NOT EXIST %EXTDEV%\WATCOM\NUL GOTO NOOW
SET WATCOM=%EXTDEV%\WATCOM
SET EDPATH=%WATCOM%\EDDAT
SET WWINHELP=%WATCOM%\BINW
SET WIPFC=%WATCOM%\WIPFC
SET PATH=%PATH%;%WATCOM%\BINW
SET INCLUDE=%WATCOM%\H;%INCLUDE%
SET FINCLUDE=%WATCOM%\SRC\FORTRAN;%WATCOM%\SRC\FORTRAN\DOS
:NOOW

REM Microsoft C
IF NOT EXIST %EXTDEV%\MSC\NUL GOTO NOMSC
SET MSC_HOME=%EXTDEV%\MSC
SET PATH=%PATH%;%MSC_HOME%\BIN
SET HELPFILES=%HELPFILES%;%MSC_HOME%\HELP
SET PATH=%PATH%;%MSC_HOME%\PROFILER\BIN;%MSC_HOME%\PROFILER\BINP
SET INCLUDE=%INCLUDE%;%MSC_HOME%\INCLUDE;%MSC_HOME%\MFC\INCLUDE
SET LIB=%LIB%;%MSC_HOME%\LIB;%MSC_HOME%\MFC\LIB
:NOMSC

REM Microsoft MASM
IF NOT EXIST %EXTDEV%\MASM\NUL GOTO NOMASM
SET MASM_HOME=%EXTDEV%\MASM
SET PATH=%PATH%;%MASM_HOME%\BIN;%MASM_HOME%\BINR
SET HELPFILES=%HELPFILES%;%MASM_HOME%\HELP
SET INCLUDE=%INCLUDE%;%MASM_HOME%\INCLUDE
:NOMASM

REM Microsoft QuickBasic
IF NOT EXIST %EXTDEV%\MQB\NUL GOTO NOQB
SET MQB_HOME=%EXTDEV%\MQB
SET PATH=%PATH%;%MQB_HOME%
SET HELPFILES=%HELPFILES%;%MQB_HOME%\HELP
SET INCLUDE=%INCLUDE%;%MQB_HOME%\INCLUDE
SET LIB=%LIB%;%MQB_HOME%\LIB
:NOQB

REM PKZIP
IF NOT EXIST %EXTDEV%\PKZIP\NUL GOTO NOPK
SET PK_HOME=%EXTDEV%\PKZIP
SET PATH=%PATH%;%PK_HOME%
:NOPK

REM EDB19 - Zip-Case-X
IF NOT EXIST %EXTDEV%\EDB19\NUL GOTO NOZCX
SET ZCX_HOME=%EXTDEV%\EDB19
SET PATH=%PATH%;%ZCX_HOME%\DOS
:NOZCX

REM UPX
IF NOT EXIST %EXTDEV%\UPX520\NUL GOTO NOUPX
SET UPX_HOME=%EXTDEV%\UPX520
SET PATH=%UPX_HOME%;%PATH%
:NOUPX

REM HWINFO
IF NOT EXIST %EXTDEV%\HWINF623\NUL GOTO NOHWINFO
SET HWINFO=%EXTDEV%\HWINF623
SET PATH=%PATH%;%HWINFO%
:NOHWINFO

REM ========== SYSTEM DRIVERS ==========

REM HX DOS Extender
SET HX_HOME=C:\HXRT216
SET PATH=%PATH%;%HX_HOME%\BIN
SET INCLUDE=%INCLUDE%;%HX_HOME%\INCLUDE
SET LIB=%LIB%;%HX_HOME%\LIB
HDPMI16 -r
HDPMI32 -r
:NOHX

REM Sound Blaster 16
SET SOUND=C:\SB16
SET BLASTER=A220 I5 D1 H5 P330 T6
SET MIDI=SYNTH:1 MAP:E
%SOUND%\DIAGNOSE /S
%SOUND%\MIXERSET /P /Q
:NOSOUND

REM MTCP Network Stack
GOTO NOMTCP
SET MTCP_HOME=C:\MTCP
SET PKTDRV_NAME=NE2000
SET PKTDRV_HOME=%MTCP_HOME%\PKTDRV\%PKTDRV_NAME%
SET PKTDRV_ARGS=0x60 3 0x300
SET PKTCFG=%PKTDRV_HOME%\%PKTDRV_NAME%.CFG
SET MTCPCFG=%MTCP_HOME%\ETC\MTCP.CFG
IF NOT EXIST %MTCPCFG% MKDIR %MTCP_HOME%\ETC
IF NOT EXIST %PKTCFG% COPY %PKTCFG% %MTCPCFG%
SET PATH=%PATH%;%MTCP_HOME%\BIN;%PKTDRV_HOME%
%PKTDRV_NAME% %PKTDRV_ARGS%
DHCP
:NOMTCP

REM ========== WINDOWS ==========
GOTO NOWIN
SET WINDIR=C:\WINDOWS
SET PATH=%PATH%;%WINDIR%
DEVICE %WINDIR%\IFSHLP.SYS
%WINDIR%\NET.EXE START
IF EXIST %WINDIR%\FAKESHAR.COM %WINDIR%\FAKESHAR.COM
%WINDIR%\WIN.COM
:NOWIN

:END
